{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wptypescript/testimonial",
  "version": "1.0.0",
  "title": "Testimonial",
  "category": "wptypescript",
  "icon": "format-quote",
  "description": "A customer testimonial with quote, author, and optional image.",
  "keywords": ["testimonial", "quote", "review"],
  "textdomain": "wptypescript",
  "attributes": {
    "quote": {
      "type": "string",
      "default": ""
    },
    "authorName": {
      "type": "string",
      "default": ""
    },
    "authorRole": {
      "type": "string",
      "default": ""
    },
    "mediaId": {
      "type": "number",
      "default": 0
    },
    "mediaUrl": {
      "type": "string",
      "default": ""
    },
    "backgroundColor": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "align": ["wide", "full"],
    "html": false
  },
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/index.css",
  "style": "file:./build/style-index.css"
}
