{
  "name": "wptypescript-theme",
  "version": "1.0.0",
  "description": "WordPress theme with TypeScript and modern build setup",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:blocks",
    "build:blocks": "node scripts/build-blocks.mjs",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@wordpress/api-fetch": "^7.48.1",
    "@wordpress/block-editor": "^15.21.1",
    "@wordpress/blocks": "^15.21.1",
    "@wordpress/components": "^35.0.1",
    "@wordpress/compose": "^8.1.1",
    "@wordpress/data": "^10.48.1",
    "@wordpress/date": "^5.48.1",
    "@wordpress/element": "^8.0.1",
    "@wordpress/hooks": "^4.48.1",
    "@wordpress/i18n": "^6.21.1",
    "@wordpress/scripts": "^32.4.1",
    "@wordpress/url": "^4.48.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup-plugin-esbuild": "^6.2.1",
    "sass": "^1.71.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.1.0"
  },
  "keywords": [
    "wordpress",
    "theme",
    "typescript",
    "vite"
  ],
  "author": "",
  "license": "GPL-2.0-or-later"
}
